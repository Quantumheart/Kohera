{
  "files.watcherExclude": {
    "**/.dart_tool/**": true,
    "**/.flutter-plugins*": true,
    "**/build/**": true,
    "**/.pub-cache/**": true,
    "**/*.mocks.dart": true,
    "**/*.g.dart": true,
    "**/*.freezed.dart": true,
    "**/.flatpak-builder/**": true,
    "**/flatpak/.flatpak-builder-build/**": true,
    "**/build-dir/**": true,
    "**/linux/flutter/ephemeral/**": true,
    "**/macos/Flutter/ephemeral/**": true,
    "**/windows/flutter/ephemeral/**": true,
    "**/ios/Pods/**": true,
    "**/ios/.symlinks/**": true,
    "**/ios/Flutter/Flutter.framework/**": true,
    "**/ios/Flutter/Flutter.podspec": true,
    "**/macos/Pods/**": true,
    "**/android/.gradle/**": true,
    "**/android/app/build/**": true,
    "**/android/build/**": true,
    "**/.idea/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true
  },
  "search.exclude": {
    "**/.dart_tool/**": true,
    "**/build/**": true,
    "**/.pub-cache/**": true,
    "**/pubspec.lock": true,
    "**/*.mocks.dart": true,
    "**/*.g.dart": true,
    "**/*.freezed.dart": true,
    "**/.flatpak-builder/**": true,
    "**/flatpak/.flatpak-builder-build/**": true,
    "**/build-dir/**": true,
    "**/linux/flutter/ephemeral/**": true,
    "**/macos/Flutter/ephemeral/**": true,
    "**/windows/flutter/ephemeral/**": true,
    "**/ios/Pods/**": true,
    "**/ios/.symlinks/**": true,
    "**/macos/Pods/**": true,
    "**/android/.gradle/**": true,
    "**/android/app/build/**": true,
    "**/android/build/**": true,
    "**/.idea/**": true,
    "**/node_modules/**": true
  },
  "files.exclude": {
    "**/.dart_tool": true,
    "**/build": true,
    "**/.flatpak-builder": true,
    "**/build-dir": true,
    "**/linux/flutter/ephemeral": true,
    "**/macos/Flutter/ephemeral": true,
    "**/windows/flutter/ephemeral": true,
    "**/ios/Pods": true,
    "**/ios/.symlinks": true,
    "**/macos/Pods": true,
    "**/android/.gradle": true
  },
  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "search.followSymlinks": false,
  "npm.exclude": [
    "**/.flatpak-builder/**",
    "**/flatpak/**"
  ]
}
